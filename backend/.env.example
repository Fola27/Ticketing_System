PORT=4000
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=
EMAIL_FROM=helpdesk@yourdomain.com
IT_TEAM_EMAIL=it-team@yourdomain.com

# Notes:
# - Register an Azure AD application and grant it the application permission `Mail.Send` (requires admin consent).
# - After granting permissions, set AZURE_CLIENT_ID, AZURE_TENANT_ID, AZURE_CLIENT_SECRET.
# - `EMAIL_FROM` must correspond to a mailbox the app is allowed to send as, or use a service account user.

# Azure Storage settings
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=tickets
